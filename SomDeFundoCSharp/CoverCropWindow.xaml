<Window x:Class="SomDeFundoCSharp.CoverCropWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajustar capa"
        Width="430"
        Height="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#080B11">
    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#F4F7FB"/>
        <Style x:Key="CropButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#18202D"/>
            <Setter Property="BorderBrush" Value="#303B4F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#202A3B"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4F8EF7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Ajustar capa" Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="Bold"/>
        <TextBlock Grid.Row="1" Text="Arraste a imagem e ajuste o zoom para definir o recorte quadrado." Foreground="#93A4B8" FontSize="12" Margin="0,6,0,16" TextWrapping="Wrap"/>

        <Border Grid.Row="2" Width="320" Height="320" Background="#0D121B" BorderBrush="#2F3A4D" BorderThickness="1" CornerRadius="10" ClipToBounds="True" HorizontalAlignment="Center">
            <Canvas x:Name="PreviewCanvas"
                    Width="320"
                    Height="320"
                    Background="#0D121B"
                    MouseLeftButtonDown="PreviewCanvas_MouseLeftButtonDown"
                    MouseLeftButtonUp="PreviewCanvas_MouseLeftButtonUp"
                    MouseMove="PreviewCanvas_MouseMove"
                    MouseWheel="PreviewCanvas_MouseWheel">
                <Image x:Name="PreviewImage"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Stretch="Fill"/>
                <Border Width="320" Height="320" BorderBrush="#60A5FA" BorderThickness="2" IsHitTestVisible="False"/>
            </Canvas>
        </Border>

        <Grid Grid.Row="3" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="52"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Zoom" Foreground="#C8D2E3" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Slider x:Name="ZoomSlider" Grid.Column="1" Minimum="1" Maximum="4" Value="1" ValueChanged="ZoomSlider_ValueChanged" VerticalAlignment="Center"/>
            <TextBlock x:Name="ZoomText" Grid.Column="2" Text="100%" Foreground="#60A5FA" FontFamily="Consolas" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button Content="Resetar" Style="{StaticResource CropButton}" Width="92" Click="Reset_Click" Margin="0,0,8,0"/>
            <Button Content="Cancelar" Style="{StaticResource CropButton}" Width="98" Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="Aplicar" Style="{StaticResource CropButton}" Width="98" Background="#2563EB" BorderBrush="#60A5FA" Click="Apply_Click"/>
        </StackPanel>
    </Grid>
</Window>
