<Window x:Class="SomDeFundoCSharp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Som de Fundo Pro"
        Width="1280"
        Height="820"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Icon="som_de_fundo_icon.ico"
        Background="#07090D">
    <Window.Resources>
        <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="Resources/Icons.xaml"/>
        </ResourceDictionary.MergedDictionaries>
        <SolidColorBrush x:Key="BgBrush" Color="#080B11"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#121722"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#0F141D"/>
        <SolidColorBrush x:Key="PanelDeepBrush" Color="#090D14"/>
        <SolidColorBrush x:Key="BorderBrushDark" Color="#253044"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F4F7FB"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#93A4B8"/>
        <SolidColorBrush x:Key="BlueBrush" Color="#3B82F6"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#10B981"/>
        <SolidColorBrush x:Key="RedBrush" Color="#EF1111"/>
        <SolidColorBrush x:Key="OrangeBrush" Color="#F97316"/>
        <SolidColorBrush x:Key="PurpleBrush" Color="#7C3AED"/>

        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="#18202D"/>
            <Setter Property="BorderBrush" Value="#303B4F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#202A3B"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4F8EF7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#60A5FA"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#EF1111"/>
            <Setter Property="BorderBrush" Value="#F43F5E"/>
        </Style>

        <Style x:Key="OrangeButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="#EA580C"/>
            <Setter Property="BorderBrush" Value="#F97316"/>
        </Style>

        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#E5EEF9"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#2A3548"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#60A5FA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LoopIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Loop}" Value="True">
                    <Setter Property="Foreground" Value="#60A5FA"/>
                    <Setter Property="Background" Value="#0B2A4A"/>
                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#93C5FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MainButtonIconBox" TargetType="Viewbox">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CardButtonIconBox" TargetType="Viewbox">
            <Setter Property="Width" Value="17"/>
            <Setter Property="Height" Value="17"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ButtonIconPath" TargetType="Path">
            <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Fill" Value="#60A5FA"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CriticalButtonIconPath" TargetType="Path">
            <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>

        <Style x:Key="MainButtonText" TargetType="TextBlock">
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Foreground" Value="#60A5FA"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CriticalButtonText" TargetType="TextBlock">
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
        </Style>

        <Style x:Key="LibraryActionButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#101827"/>
            <Setter Property="BorderBrush" Value="#263B5F"/>
        </Style>

        <Style x:Key="TransparentPadButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#111827"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#0B1220"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PadShell" TargetType="Border">
            <Setter Property="Background" Value="#151B26"/>
            <Setter Property="BorderBrush" Value="#283347"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                    <Setter Property="BorderBrush" Value="#34D399"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding HasMissingAudio}" Value="True">
                    <Setter Property="BorderBrush" Value="#F87171"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0D121B"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#263041"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="SelectionBrush" Value="#2563EB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0D121B"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#263041"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="#0D121B"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#263041"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="#0D121B"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Padding" Value="6"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#111620"/>
            <Setter Property="BorderBrush" Value="#263041"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#AAB4C5"/>
            <Setter Property="Background" Value="#0D121B"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#263041"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabRoot" Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabRoot" Property="Background" Value="#172033"/>
                                <Setter Property="Foreground" Value="#E5F0FF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabRoot" Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#111B2A"/>
            <Setter Property="Foreground" Value="#C8D2E3"/>
            <Setter Property="BorderBrush" Value="#263041"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="10" Margin="14,14,14,7" Padding="16,14">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Width="292">
                    <Border Width="48" Height="48" CornerRadius="10" Background="#0B0F16" BorderBrush="#2E3A50" BorderThickness="1" Margin="0,0,12,0" ClipToBounds="True">
                        <Image Source="ICONE SOM DE FUNDO.png" Stretch="Uniform" Margin="4" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="SOM DE FUNDO" Foreground="{StaticResource TextBrush}" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text=" PRO" Foreground="#60A5FA" FontSize="18" FontStyle="Italic" Margin="6,1,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Ellipse Fill="#10B981" Width="8" Height="8" Margin="0,0,7,0"/>
                            <TextBlock Text="CONSOLE ATIVO" Foreground="#10B981" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <Button DockPanel.Dock="Right" Style="{StaticResource RoundedButton}" Click="AboutButton_Click" Width="86" Margin="14,0,0,0" Padding="8,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Viewbox Style="{StaticResource MainButtonIconBox}">
                            <Path Data="{StaticResource IconInfo}" Style="{StaticResource ButtonIconPath}"/>
                        </Viewbox>
                        <TextBlock Text="Sobre" Style="{StaticResource MainButtonText}"/>
                    </StackPanel>
                </Button>

                <Border Background="#090D14" BorderBrush="#2A3548" BorderThickness="1" CornerRadius="8" Padding="12,8" VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="MODO - STANDBY" Foreground="#60A5FA" FontSize="11" FontWeight="Bold"/>
                        <TextBlock x:Name="NowPlayingText" Grid.Column="1" Text="Nenhum som ativo" Foreground="{StaticResource TextBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="TimeText" Grid.Column="2" Text="00:00 / 00:00" Foreground="#8B95A7" FontSize="11" FontFamily="Consolas" HorizontalAlignment="Right"/>
                        <ProgressBar x:Name="PlaybackProgress"
                                     Grid.Row="1"
                                     Grid.ColumnSpan="3"
                                     Height="7"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"
                                     Margin="0,8,0,0"
                                      Foreground="#3B82F6"
                                      Background="#18202D"
                                      BorderBrush="#18202D"
                                     Cursor="Hand"
                                     ToolTip="Clique para avancar ou voltar no tempo"
                                     MouseLeftButtonDown="PlaybackProgress_MouseLeftButtonDown"/>
                    </Grid>
                </Border>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="10" Margin="14,7" Padding="16">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Border Background="#090D14" BorderBrush="#2A3548" BorderThickness="1" CornerRadius="7" Padding="12,8" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PLAYLIST:" Foreground="#8B95A7" FontSize="12" FontWeight="Bold" Margin="0,0,8,0"/>
                            <ComboBox x:Name="PlaylistSelector"
                                      Width="190"
                                      Height="32"
                                      FontSize="12"
                                      FontWeight="Bold"
                                      Padding="8,3"
                                      VerticalContentAlignment="Center"
                                      SelectionChanged="PlaylistSelector_SelectionChanged"/>
                            <TextBlock x:Name="PlaylistNameText" Text="Default" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource RoundedButton}" Click="NewPlaylist_Click" Margin="0,0,8,0" Padding="10,8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Viewbox Style="{StaticResource MainButtonIconBox}">
                                <Path Data="{StaticResource IconAdd}" Style="{StaticResource ButtonIconPath}"/>
                            </Viewbox>
                            <TextBlock Text="Nova" Style="{StaticResource MainButtonText}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RoundedButton}" Click="DuplicatePlaylist_Click" Margin="0,0,8,0" Padding="10,8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Viewbox Style="{StaticResource MainButtonIconBox}">
                                <Path Data="{StaticResource IconCopy}" Style="{StaticResource ButtonIconPath}"/>
                            </Viewbox>
                            <TextBlock Text="Duplicar" Style="{StaticResource MainButtonText}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RoundedButton}" Foreground="#F87171" Click="DeletePlaylist_Click" Margin="0,0,8,0" Padding="10,8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Viewbox Style="{StaticResource MainButtonIconBox}">
                                <Path Data="{StaticResource IconDelete}" Style="{StaticResource CriticalButtonIconPath}"/>
                            </Viewbox>
                            <TextBlock Text="Excluir" Style="{StaticResource CriticalButtonText}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RoundedButton}" Click="EditPlaylist_Click" Padding="10,8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Viewbox Style="{StaticResource MainButtonIconBox}">
                                <Path Data="{StaticResource IconEdit}" Style="{StaticResource ButtonIconPath}"/>
                            </Viewbox>
                            <TextBlock Text="Editar" Style="{StaticResource MainButtonText}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border DockPanel.Dock="Right" Background="#090D14" BorderBrush="#2A3548" BorderThickness="1" CornerRadius="8" Padding="12,8" Width="410">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="52"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                            <Viewbox Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconVolume}" Fill="#C8D2E3" Stretch="Uniform"/>
                            </Viewbox>
                            <TextBlock Text="VOLUME GERAL:" Foreground="#C8D2E3" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="7,0,0,0"/>
                        </StackPanel>
                        <Slider x:Name="MasterVolumeSlider" Grid.Column="1" Minimum="0" Maximum="100" Value="80" ValueChanged="MasterVolumeSlider_ValueChanged" VerticalAlignment="Center"/>
                        <TextBlock x:Name="MasterVolumeText" Grid.Column="2" Text="80%" Foreground="#60A5FA" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="2" Margin="6,0" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="PadsList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding GridColumns, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource PadShell}" Margin="9" Height="{Binding DataContext.PadHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="5"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="40"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{Binding ColorBrush}" CornerRadius="8,8,0,0"/>

                                <Button Grid.Row="1" Style="{StaticResource TransparentPadButton}" Click="Pad_Click" Tag="{Binding}">
                                    <Grid Margin="12,10,12,8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding NumberLabel}" Foreground="#94A3B8" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding VolumeLabel}" Foreground="#3B82F6" FontFamily="Consolas" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        <Border Grid.Row="1" Width="58" Height="58" Background="#0A0F17" BorderBrush="#2A3548" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="True">
                                            <Image Source="{Binding CoverImageSource}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <TextBlock Grid.Row="2" Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontSize="13" FontWeight="Bold" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Row="3" Text="{Binding AudioStatusText}" Foreground="{Binding AudioStatusBrush}" FontSize="10" FontWeight="SemiBold" TextAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    </Grid>
                                </Button>

                                <Grid Grid.Row="2" Background="#121A27">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="32"/>
                                        <ColumnDefinition Width="32"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="V" Foreground="#64748B" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding LoopLabel}" Foreground="#64748B" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Button Grid.Column="3" Style="{StaticResource IconButton}" ToolTip="Configurar" Click="OpenPadEditor_Click" Tag="{Binding}">
                                        <Viewbox Style="{StaticResource CardButtonIconBox}">
                                            <Path Data="{StaticResource IconSettings}" Style="{StaticResource ButtonIconPath}"/>
                                        </Viewbox>
                                    </Button>
                                    <Button Grid.Column="4" Style="{StaticResource IconButton}" ToolTip="Recursos de IA" Click="OpenPadAi_Click" Tag="{Binding}">
                                        <Viewbox Style="{StaticResource CardButtonIconBox}">
                                            <Path Data="{StaticResource IconWand}" Style="{StaticResource ButtonIconPath}"/>
                                        </Viewbox>
                                    </Button>
                                    <Button Grid.Column="5" Style="{StaticResource LoopIconButton}" ToolTip="Repetição" Click="LoopPad_Click" Tag="{Binding}">
                                        <Viewbox Style="{StaticResource CardButtonIconBox}">
                                            <Path Data="{StaticResource IconRepeat}" Style="{StaticResource ButtonIconPath}"/>
                                        </Viewbox>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#111722" BorderBrush="#2A3548" BorderThickness="1" CornerRadius="9" Margin="6,0,6,8" Padding="14,9">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Ellipse x:Name="StatusDot" Fill="#334155" Width="10" Height="10" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Text="Parado - Aguardando Fundo" Foreground="#D8DEE9" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock x:Name="CrossfadeText" DockPanel.Dock="Right" Text="Crossfade: 3s" Foreground="#7C8497" FontFamily="Consolas" FontSize="12"/>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="10" Margin="6,6,6,14" Padding="16,12">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource DangerButton}" Click="StopButton_Click" Width="86" Height="40" Margin="0,0,8,0" Padding="7,8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Viewbox Style="{StaticResource MainButtonIconBox}">
                                    <Path Data="{StaticResource IconStop}" Style="{StaticResource CriticalButtonIconPath}"/>
                                </Viewbox>
                                <TextBlock Text="Parar" Style="{StaticResource CriticalButtonText}" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource OrangeButton}" Click="PauseResume_Click" Width="124" Height="40" Padding="7,8" FontSize="11">
