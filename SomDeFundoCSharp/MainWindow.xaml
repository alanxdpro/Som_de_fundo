                                                    <Button Content="Prev" Tag="{Binding}" Style="{StaticResource LibraryActionButton}" Click="PreviewOnline_Click" Margin="0,0,6,0"/>
                                                    <Button Content="Baix" Tag="{Binding}" Style="{StaticResource LibraryActionButton}" Click="DownloadOnline_Click" Margin="0,0,6,0"/>
                                                    <Button Content="Votar" Tag="{Binding}" Style="{StaticResource LibraryActionButton}" Click="LikeAudio_Click" Width="58" Margin="0,0,6,0"/>
                                                    <Button Content="Adicionar" ToolTip="Adicionar ao botao" Tag="{Binding}" Style="{StaticResource LibraryActionButton}" Click="UseOnline_Click" Width="82"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                        <Grid Grid.Row="1" Margin="0,14,0,0">
                            <TextBlock Text="Selecione uma musica ou use os botoes da linha." Foreground="#8B95A7" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Previa" Style="{StaticResource RoundedButton}" Click="PreviewOnline_Click" Width="140" Margin="0,0,10,0"/>
                                <Button Content="Votar" Style="{StaticResource PrimaryButton}" Click="LikeAudio_Click" Width="130" Margin="0,0,10,0"/>
                                <Button Content="Baixar" Style="{StaticResource RoundedButton}" Click="DownloadOnline_Click" Width="120" Margin="0,0,10,0"/>
                                <Button Content="Adicionar ao botao" Style="{StaticResource PrimaryButton}" Click="UseOnline_Click" Width="170" Margin="0,0,10,0"/>
                                <Button Content="Anterior" Style="{StaticResource RoundedButton}" Click="PreviousCommunityPage_Click" Width="110" Margin="0,0,10,0"/>
                                <Button Content="Proxima" Style="{StaticResource RoundedButton}" Click="NextCommunityPage_Click" Width="110"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Grid x:Name="VotingLibraryPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Background="#0D1B2E" BorderBrush="#1D4ED8" BorderThickness="1" CornerRadius="7" Padding="14" Margin="0,0,0,12">
                            <TextBlock x:Name="AdminStatusText" Text="Area administrativa: cadastre seu User ID em admin_users para liberar as acoes." Foreground="#AAB4C5" TextWrapping="Wrap"/>
                        </Border>
                        <ListView x:Name="VotingAudiosList" Grid.Row="1">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Titulo" DisplayMemberBinding="{Binding Name}" Width="210"/>
                                    <GridViewColumn Header="Artista / Enviado por" DisplayMemberBinding="{Binding ArtistUploaderLabel}" Width="210"/>
                                    <GridViewColumn Header="Duracao" DisplayMemberBinding="{Binding DurationLabel}" Width="90"/>
                                    <GridViewColumn Header="Tamanho" DisplayMemberBinding="{Binding SizeLabel}" Width="90"/>
                                    <GridViewColumn Header="Votos" DisplayMemberBinding="{Binding Votes}" Width="70"/>
                                    <GridViewColumn Header="Downloads" DisplayMemberBinding="{Binding Downloads}" Width="80"/>
                                    <GridViewColumn Header="Status" DisplayMemberBinding="{Binding ApprovalLabel}" Width="90"/>
                                </GridView>
                            </ListView.View>
                        </ListView>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                            <Button Content="Baixar" Style="{StaticResource RoundedButton}" Click="DownloadOnline_Click" Width="90" Margin="0,0,8,0"/>
                            <Button Content="Adicionar Biblioteca" Style="{StaticResource RoundedButton}" Click="DownloadOnline_Click" Width="150" Margin="0,0,8,0"/>
                            <Button Content="Adicionar ao botao" Style="{StaticResource PrimaryButton}" Click="UseOnline_Click" Width="150" Margin="0,0,8,0"/>
                            <Button Content="Aprovar" Style="{StaticResource PrimaryButton}" Click="ApproveCommunityMusic_Click" Width="90" Margin="0,0,8,0"/>
                            <Button Content="Excluir" Style="{StaticResource DangerButton}" Click="DeleteCommunityMusic_Click" Width="90" Margin="0,0,8,0"/>
                            <Button Content="Ant" Style="{StaticResource RoundedButton}" Click="PreviousAdminPage_Click" Width="58" Margin="0,0,8,0"/>
                            <Button Content="Prox" Style="{StaticResource RoundedButton}" Click="NextAdminPage_Click" Width="58"/>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="UploadLibraryPanel" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="#111B2A" BorderBrush="#2F3A4D" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,18,0">
                                <StackPanel>
                                    <Border Width="42" Height="42" HorizontalAlignment="Left" Background="#2563EB" CornerRadius="8" Margin="0,0,0,14">
                                        <TextBlock Text=">" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Enviar musica para comunidade" Foreground="{StaticResource TextBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                                    <TextBlock Text="Sua musica fica disponivel para a comunidade ouvir, votar e baixar." Foreground="#AAB4C5" TextWrapping="Wrap" Margin="0,0,0,18"/>
                                    <Border Background="#0D121B" BorderBrush="#263041" BorderThickness="1" CornerRadius="7" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Regras para envio" Foreground="#60A5FA" FontWeight="Bold" Margin="0,0,0,8"/>
                                            <TextBlock Text="- Arquivos: MP3, WAV ou M4A" Foreground="#AAB4C5" Margin="0,0,0,5"/>
                                            <TextBlock Text="- Tamanho maximo: 60 MB" Foreground="#AAB4C5" Margin="0,0,0,5"/>
                                            <TextBlock Text="- Duracao maxima: 2 horas" Foreground="#AAB4C5"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Titulo da musica" Foreground="#AAB4C5" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBox x:Name="UploadNameBox" Text="Meu som"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Artista" Foreground="#AAB4C5" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBox x:Name="UploadArtistBox" Text="Comunidade"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Enviado por" Foreground="#AAB4C5" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBox x:Name="UploadSenderBox"/>
                                        <TextBlock Text="Este nome aparece para a comunidade." Foreground="#8B95A7" FontSize="11" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Arquivo de audio" Foreground="#AAB4C5" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="UploadFileText" IsReadOnly="True"/>
                                            <Button Grid.Column="1" Content="Selecionar" Style="{StaticResource RoundedButton}" Click="SelectCommunityUploadFile_Click" Margin="8,0,0,0"/>
                                        </Grid>
                                        <TextBlock Text="Formatos: MP3, WAV, M4A - max 60 MB - max 2 horas" Foreground="#8B95A7" FontSize="11" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Grid.Row="2" Margin="0,12,0,0">
                                    <TextBlock Text="Observacao (opcional)" Foreground="#AAB4C5" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBox x:Name="UploadNoteBox" Height="70" TextWrapping="Wrap" AcceptsReturn="True"/>
                                </StackPanel>
                                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                    <Button Content="Limpar formulario" Style="{StaticResource RoundedButton}" Click="ClearCommunityUpload_Click" Width="150" Margin="0,0,10,0"/>
                                    <Button Content="Enviar para Votacao" Style="{StaticResource PrimaryButton}" Click="UploadAudio_Click" Width="210" Height="42"/>
                                </StackPanel>
                                <TextBlock Grid.Row="5" x:Name="UploadStatusText" Foreground="#8B95A7" Margin="0,12,0,0" TextWrapping="Wrap"/>
                            </Grid>
                        </Grid>
                    </Grid>

                    <Grid x:Name="AdminCleanupPanel" Visibility="Collapsed">
                        <StackPanel Width="620" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Administrador - Limpeza Automatica" Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="Bold" Margin="0,0,0,14"/>
                            <Border Background="#0D121B" BorderBrush="#263041" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock x:Name="CommunityUserIdText" Text="User ID: -" Foreground="#BFDBFE" FontFamily="Consolas" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="AdminStorageText" Text="Uso: -" Foreground="#86EFAC" FontWeight="SemiBold" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="CleanupStatusText" Text="A limpeza roda quando um admin abre esta area." Foreground="#AAB4C5" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Copiar User ID" Style="{StaticResource RoundedButton}" Click="CopyCommunityUserId_Click" Width="120" Margin="0,0,8,0"/>
                                <Button Content="Rodar Limpeza" Style="{StaticResource PrimaryButton}" Click="RunCommunityCleanup_Click" Width="130"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="SqlLibraryPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                            <Button Content="Copiar SQL" Style="{StaticResource RoundedButton}" Click="CopySupabaseSql_Click" Width="110" Margin="0,0,8,0"/>
                            <Button Content="Testar conexao" Style="{StaticResource PrimaryButton}" Click="TestSupabase_Click" Width="130"/>
                        </StackPanel>
                        <TextBox x:Name="SupabaseSqlBox"
                                 Grid.Row="1"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Background="#0D121B"
                                 Foreground="#D1D5DB"
                                 BorderBrush="#263041"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
